{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/presentation/**",
              "designsystem.app.jsx",
              "slides/**",
              "ui_kits/master-template-generator/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|dot|shape|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant, dot, shape."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|neutral|success|warning|error|info)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'neutral' | 'success' | 'warning' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:subtle|solid)$/]",
        "message": "<Badge> variant must be one of 'subtle' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:pill|square)$/]",
        "message": "<Badge> shape must be one of 'pill' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|radius|iconLeft|iconRight|fullWidth|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, radius, iconLeft, iconRight, fullWidth, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|brand|secondary|outline|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'brand' | 'secondary' | 'outline' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:sharp|md|full)$/]",
        "message": "<Button> radius must be one of 'sharp' | 'md' | 'full'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:surface|elevation|radius|padding|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: surface, elevation, radius, padding."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:default|subtle|sunken)$/]",
        "message": "<Card> surface must be one of 'default' | 'subtle' | 'sunken'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:flat|soft|lift)$/]",
        "message": "<Card> elevation must be one of 'flat' | 'soft' | 'lift'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:sharp|md|lg|xl)$/]",
        "message": "<Card> radius must be one of 'sharp' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|indeterminate|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, indeterminate, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:center|size|color|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: center, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='HudBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|num|dark|position|key|ref|className|style|children)$/]",
        "message": "<HudBar> doesn't accept that prop. Declared props: label, num, dark, position."
      },
      {
        "selector": "JSXOpeningElement[name.name='HudBar'] > JSXAttribute[name.name='position'] > Literal[value!=/^(?:absolute|static)$/]",
        "message": "<HudBar> position must be one of 'absolute' | 'static'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tone|size|label|active|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, tone, size, label, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|brand|danger)$/]",
        "message": "<IconButton> tone must be one of 'neutral' | 'brand' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|size|disabled|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, size, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricValue'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|heading|valueSize|headingSize|key|ref|className|style|children)$/]",
        "message": "<MetricValue> doesn't accept that prop. Declared props: value, unit, heading, valueSize, headingSize."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|disabled|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: label, checked, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SlideFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:dark|showGrid|glow|fit|key|ref|className|style|children)$/]",
        "message": "<SlideFrame> doesn't accept that prop. Declared props: dark, showGrid, glow, fit."
      },
      {
        "selector": "JSXOpeningElement[name.name='SlideFrame'] > JSXAttribute[name.name='fit'] > Literal[value!=/^(?:width|none)$/]",
        "message": "<SlideFrame> fit must be one of 'width' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: label, checked, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|message|tone|onClose|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: title, message, tone, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|error|info|brand)$/]",
        "message": "<Toast> tone must be one of 'success' | 'error' | 'info' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placement|children|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: label, placement, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute[name.name='placement'] > Literal[value!=/^(?:top|bottom|left|right)$/]",
        "message": "<Tooltip> placement must be one of 'top' | 'bottom' | 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadZone'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|filename|subtext|validating|accept|onFileSelect|key|ref|className|style|children)$/]",
        "message": "<UploadZone> doesn't accept that prop. Declared props: title, filename, subtext, validating, accept, onFileSelect."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
